# Production Dockerfile for App Runner / ECS deployment.
#
# Differences from Dockerfile (dev):
#   - Multi-stage build: smaller final image
#   - Bakes the ingested data/ directory INTO the image (chunks, images, cache)
#     so the container is self-contained on App Runner (no persistent volume
#     required). Re-ingestion = rebuild + redeploy.
#   - Reads OPENAI_API_KEY and PINECONE_API_KEY from environment (App Runner
#     wires them in from Secrets Manager).
#   - Listens on $PORT (App Runner injects PORT=8080 by default).

FROM python:3.12-slim AS deps

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        poppler-utils libgl1 libglib2.0-0 curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install -e .


FROM python:3.12-slim AS runtime

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONIOENCODING=utf-8 \
    RAGQA_DATA_DIR=/app/data \
    PORT=8080

RUN apt-get update && apt-get install -y --no-install-recommends \
        poppler-utils libgl1 libglib2.0-0 curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --shell /bin/bash app

WORKDIR /app
COPY --from=deps /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=deps /usr/local/bin/uvicorn /usr/local/bin/uvicorn
COPY --from=deps /app/src /app/src
COPY --from=deps /app/pyproject.toml /app/README.md /app/

# Bake the ingested data into the image. Build context must include
# backend/data/ - .dockerignore handles selective inclusion.
COPY data ./data
COPY scripts ./scripts

RUN chown -R app:app /app
USER app

EXPOSE 8080

HEALTHCHECK --interval=20s --timeout=3s --retries=3 --start-period=15s \
    CMD curl -fsS http://localhost:${PORT}/health || exit 1

# App Runner uses PORT; locally you can override.
CMD ["sh", "-c", "uvicorn ragqa.main:app --host 0.0.0.0 --port ${PORT}"]
