# --- Required ---
OPENAI_API_KEY=sk-proj-...
PINECONE_API_KEY=pcsk_...

# --- Models ---
RAGQA_VLM_MODEL=gpt-4o
RAGQA_LLM_MODEL=gpt-4o
RAGQA_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RAGQA_EMBEDDING_DIM=1024
RAGQA_RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v2

# Optional: for self-hosted / Azure OpenAI compatible endpoints
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Storage ---
RAGQA_DATA_DIR=./data

# --- Pinecone ---
RAGQA_PINECONE_INDEX=ragqa-chunks
RAGQA_PINECONE_CLOUD=aws
RAGQA_PINECONE_REGION=us-east-1
RAGQA_PINECONE_NAMESPACE=v1
RAGQA_PINECONE_METRIC=dotproduct  # required for sparse-dense hybrid
RAGQA_PINECONE_BATCH_SIZE=64

# --- API ---
RAGQA_HOST=127.0.0.1
RAGQA_PORT=8000
RAGQA_CORS_ORIGINS=http://localhost:3000
RAGQA_API_KEY=  # leave blank to disable, set in prod

# --- Retrieval defaults ---
RAGQA_TOP_K=20
RAGQA_RERANK_TOP_K=5
RAGQA_HYBRID_ALPHA=0.6  # 0=BM25 only, 1=dense only

# --- Generation defaults ---
RAGQA_MAX_OUTPUT_TOKENS=1024
RAGQA_TEMPERATURE=0.2
RAGQA_MAX_IMAGES_PER_ANSWER=4

# --- Observability ---
RAGQA_LOG_LEVEL=INFO
RAGQA_LOG_JSON=false
