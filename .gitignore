__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Node / Next.js ---
node_modules/
.next/
out/
dist/
*.log
.turbo/

# --- IDE / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

