# URL the Next.js server uses to call the FastAPI backend (server-side only).
# In Docker compose this is http://backend:8000.
BACKEND_URL=http://localhost:8000

# What the browser hits to view served PDF page-images. Defaults to same-origin.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional: forwarded to backend as X-API-Key if RAGQA_API_KEY is enforced.
RAGQA_API_KEY=
